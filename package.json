{
  "name": "self-abyssal-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names backend,mobile --prefix-colors cyan,magenta \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "docker compose -f packages/backend/docker-compose.yml up --build",
    "dev:backend:local": "npm --workspace @abyssal/backend run dev",
    "dev:backend:down": "docker compose -f packages/backend/docker-compose.yml down -v",
    "dev:mobile": "npm --workspace @abyssal/mobile run start",
    "seed:backend": "npm --workspace @abyssal/backend run seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  }
}
