{
  "name": "self-abyssal-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:web": "node scripts/dev.js --web",
    "dev:backend": "docker compose -f packages/backend/docker-compose.yml up --build",
    "dev:backend:detached": "docker compose -f packages/backend/docker-compose.yml up --build -d",
    "dev:backend:down": "docker compose -f packages/backend/docker-compose.yml down -v",
    "build:backend": "mvn -f packages/backend/pom.xml package",
    "test:backend": "mvn -f packages/backend/pom.xml test",
    "dev:mobile": "npm --workspace @abyssal/mobile run start",
    "dev:mobile:web": "npm --workspace @abyssal/mobile run web"
  }
}
